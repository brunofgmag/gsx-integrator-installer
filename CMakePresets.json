{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "msvc-qt-base",
            "hidden": true,
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "toolset": {
                "value": "host=x64",
                "strategy": "set"
            },
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "BUILD_TESTING": "ON",
                "CMAKE_PREFIX_PATH": "$env{QT_ROOT_DIR}"
            }
        },
        {
            "name": "debug",
            "displayName": "Qt MSVC 2022 x64 - Debug",
            "inherits": "msvc-qt-base"
        },
        {
            "name": "release",
            "displayName": "Qt MSVC 2022 x64 - Release",
            "inherits": "msvc-qt-base"
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Build Qt MSVC Debug",
            "configurePreset": "debug",
            "configuration": "Debug"
        },
        {
            "name": "release",
            "displayName": "Build Qt MSVC Release",
            "configurePreset": "release",
            "configuration": "Release"
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "displayName": "Test Qt MSVC Debug",
            "configurePreset": "debug",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "release",
            "displayName": "Test Qt MSVC Release",
            "configurePreset": "release",
            "configuration": "Release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
